# Optional: shared trip state on Vercel (recommended)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Redis key (default trip:document)
# TRIP_REDIS_KEY=trip:document

# Optional CORS / Socket.IO origins (comma-separated), when UI and API differ
# CLIENT_ORIGIN=https://your-domain.com
